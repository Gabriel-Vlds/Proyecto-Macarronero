# Variables de entorno de ejemplo para el backend

# Server
PORT=3000
FRONTEND_URL=http://localhost:4200
CORS_ORIGIN=http://localhost:4200

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=macarronero

# Auth
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_key
STRIPE_SUCCESS_URL=http://localhost:4200/courses?checkout=success
STRIPE_CANCEL_URL=http://localhost:4200/courses?checkout=cancel

# Mux
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
